{
  "name": "freestyle-plugin-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A minimal example Freestyle plugin — copy this folder to start your own.",
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "freestyle": {
    "icon": "Puzzle",
    "contributes": {
      "pages": [
        {
          "id": "example",
          "title": "Example Plugin",
          "entry": "dist/ui/index.html"
        }
      ]
    }
  },
  "scripts": {
    "build": "pkgroll --minify && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "freestyle-voice": "workspace:*"
  },
  "devDependencies": {
    "pkgroll": "^2.27.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
